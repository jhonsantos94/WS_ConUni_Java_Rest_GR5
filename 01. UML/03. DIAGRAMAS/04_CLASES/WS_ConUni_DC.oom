<c:Classes>
<o:Class Id="o53">
<a:ObjectID>BBFE76BF-ED8A-42FB-8B80-2894EF5EF193</a:ObjectID>
<a:Name>ManejadorAutenticacion</a:Name>
<a:Code>ManejadorAutenticacion</a:Code>
<a:CreationDate>1777389587</a:CreationDate>
<a:Creator>dario</a:Creator>
<a:ModificationDate>1777389587</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:UseParentNamespace>0</a:UseParentNamespace>
<a:Classifier.Header> </a:Classifier.Header>
<a:Imports>import ec.edu.monster.seguridad.AdministradorTokens;
import jakarta.annotation.Priority;
import jakarta.ws.rs.Priorities;
import jakarta.ws.rs.container.ContainerRequestContext;
import jakarta.ws.rs.container.ContainerRequestFilter;
import jakarta.ws.rs.core.HttpHeaders;
import jakarta.ws.rs.core.MediaType;
import jakarta.ws.rs.core.Response;
import jakarta.ws.rs.ext.Provider;
</a:Imports>
<c:Operations>
<o:Operation Id="o55">
<a:ObjectID>9C02A757-1143-4D38-9662-E289F6D89DF4</a:ObjectID>
<a:Name>filter</a:Name>
<a:Code>filter</a:Code>
<a:CreationDate>1777389587</a:CreationDate>
<a:Creator>dario</a:Creator>
<a:ModificationDate>1777389587</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:ReturnType>void</a:ReturnType>
<a:TemplateBody>{
    String ruta = contexto.getUriInfo().getPath();
    if (ruta == null) {
        ruta = &quot;&quot;;
    }

    if (&quot;OPTIONS&quot;.equalsIgnoreCase(contexto.getMethod()) || ruta.endsWith(&quot;/login&quot;)) {
        return;
    }

    String cabeceraAutorizacion = contexto.getHeaderString(HttpHeaders.AUTHORIZATION);
    if (cabeceraAutorizacion == null || cabeceraAutorizacion.isBlank()) {
        rechazar(contexto, &quot;Acceso denegado: Se requiere el encabezado Authorization con el token.&quot;);
        return;
    }

    String token = extraerToken(cabeceraAutorizacion);
    if (token.isBlank() || !AdministradorTokens.validarToken(token)) {
        rechazar(contexto, &quot;Acceso denegado: Token invalido o expirado.&quot;);
    }
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o56">
<a:ObjectID>135A234E-A76E-4F9F-BF90-B814397C5CE8</a:ObjectID>
<a:Name>contexto</a:Name>
<a:Code>contexto</a:Code>
<a:CreationDate>1777389587</a:CreationDate>
<a:Creator>dario</a:Creator>
<a:ModificationDate>1777389587</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:Parameter.DataType>ContainerRequestContext</a:Parameter.DataType>
</o:Parameter>
</c:Parameters>
<c:Annotations>
<o:Annotation Id="o57">
<a:ObjectID>053FDD7D-C222-46C6-9533-F61830AF0C31</a:ObjectID>
<a:CreationDate>1777389587</a:CreationDate>
<a:Creator>dario</a:Creator>
<a:ModificationDate>1777389587</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:Annotation.Name>Override</a:Annotation.Name>
</o:Annotation>
</c:Annotations>
</o:Operation>
<o:Operation Id="o58">
<a:ObjectID>2616F749-232C-4CD6-ADCC-5B6556FB9659</a:ObjectID>
<a:Name>extraerToken</a:Name>
<a:Code>extraerToken</a:Code>
<a:CreationDate>1777389587</a:CreationDate>
<a:Creator>dario</a:Creator>
<a:ModificationDate>1777389587</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:ReturnType>String</a:ReturnType>
<a:Operation.Visibility>-</a:Operation.Visibility>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    String prefijo = &quot;Bearer &quot;;
    if (cabeceraAutorizacion.regionMatches(true, 0, prefijo, 0, prefijo.length())) {
        return cabeceraAutorizacion.substring(prefijo.length()).trim();
    }
    return cabeceraAutorizacion.trim();
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o59">
<a:ObjectID>EE1B41AD-04CF-4147-944F-90203CDCB769</a:ObjectID>
<a:Name>cabeceraAutorizacion</a:Name>
<a:Code>cabeceraAutorizacion</a:Code>
<a:CreationDate>1777389587</a:CreationDate>
<a:Creator>dario</a:Creator>
<a:ModificationDate>1777389587</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:Parameter.DataType>String</a:Parameter.DataType>
</o:Parameter>
</c:Parameters>
</o:Operation>
<o:Operation Id="o60">
<a:ObjectID>705D3498-2543-42B6-9966-59E8E0A7B62A</a:ObjectID>
<a:Name>rechazar</a:Name>
<a:Code>rechazar</a:Code>
<a:CreationDate>1777389587</a:CreationDate>
<a:Creator>dario</a:Creator>
<a:ModificationDate>1777389587</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:ReturnType>void</a:ReturnType>
<a:Operation.Visibility>-</a:Operation.Visibility>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    String json = &quot;{\&quot;mensaje\&quot;:\&quot;&quot; + escaparJson(mensaje) + &quot;\&quot;}&quot;;
    Response respuesta = Response.status(Response.Status.UNAUTHORIZED)
            .type(MediaType.APPLICATION_JSON)
            .entity(json)
            .build();
    contexto.abortWith(respuesta);
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o61">
<a:ObjectID>EDD6F63F-EF7C-4ED6-B050-F0E2F5A4F718</a:ObjectID>
<a:Name>contexto</a:Name>
<a:Code>contexto</a:Code>
