<o:Operation Id="o63">
<a:ObjectID>DE294036-516C-4763-9770-1FC87FC24191</a:ObjectID>
<a:Name>escaparJson</a:Name>
<a:Code>escaparJson</a:Code>
<a:CreationDate>1777389587</a:CreationDate>
<a:Creator>dario</a:Creator>
<a:ModificationDate>1777389587</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:ReturnType>String</a:ReturnType>
<a:Operation.Visibility>-</a:Operation.Visibility>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    if (texto == null) {
        return &quot;&quot;;
    }
    return texto.replace(&quot;\\&quot;, &quot;\\\\&quot;).replace(&quot;\&quot;&quot;, &quot;\\\&quot;&quot;);
}
</a:TemplateBody>
