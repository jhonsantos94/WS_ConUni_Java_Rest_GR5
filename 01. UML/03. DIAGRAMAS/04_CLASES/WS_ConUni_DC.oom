<o:Operation Id="o286">
<a:ObjectID>402971E4-8B79-4EE4-ACED-4929D0C3BFD6</a:ObjectID>
<a:Name>convertir</a:Name>
<a:Code>convertir</a:Code>
<a:CreationDate>1777389588</a:CreationDate>
<a:Creator>dario</a:Creator>
<a:ModificationDate>1777389588</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:ReturnType>double</a:ReturnType>
<a:TemplateBody>{

    if (unidadOrigen == null || unidadFinal == null) {
        throw new IllegalArgumentException(&quot;Las unidades no pueden ser null&quot;);
    }
    if (!factores.containsKey(unidadOrigen) || !factores.containsKey(unidadFinal)) {
        throw new IllegalArgumentException(&quot;Unidad no soportada&quot;);
    }

    double valorEnBase = valor * factores.get(unidadOrigen);

    return valorEnBase / factores.get(unidadFinal);
}
</a:TemplateBody>
