<a:ModificationDate>1777389589</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:ReturnType>Set&lt;String&gt;</a:ReturnType>
<a:Operation.Visibility>-</a:Operation.Visibility>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    return Arrays.stream(valorPorDefecto(valor, valorDefecto).split(&quot;,&quot;))
            .map(String::trim)
            .filter(s -&gt; !s.isEmpty())
            .collect(Collectors.toCollection(LinkedHashSet::new));
}
</a:TemplateBody>
