<o:Operation Id="o342">
<a:ObjectID>21045D8D-886E-41D5-9C6C-3F074451EDB9</a:ObjectID>
<a:Name>cambiarContrasenia</a:Name>
<a:Code>cambiarContrasenia</a:Code>
<a:CreationDate>1777389588</a:CreationDate>
<a:Creator>dario</a:Creator>
<a:ModificationDate>1777389588</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:ReturnType>void</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    if (!contrasenia.equals(contraseniaActual)) {
        throw new RuntimeException(&quot;La contrasenia actual es incorrecta&quot;);
    }

    if (contraseniaNueva == null || contraseniaNueva.isBlank()) {
        throw new RuntimeException(&quot;La nueva contrasenia es obligatoria&quot;);
    }

    contrasenia = contraseniaNueva;
}
</a:TemplateBody>
<a:ExtendedAttributesText>{0DEDDB90-46E2-45A0-886E-411709DA0DC9},Java,60={974CB4C7-4E83-4A28-8572-1D6332912398},synchronized,4=true

